rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════
// Reglas de seguridad — Barsa Soacha Academy
// Roles: admin > coordinator > coach > parent (ver ROLES en firebase-config.js)
// ══════════════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myRole() {
      return (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isAdmin()       { return myRole() == 'admin'; }
    function isCoordinator() { return myRole() in ['admin', 'coordinator']; }
    function isStaff()       { return myRole() in ['admin', 'coordinator', 'coach']; }
    function myEmail()       { return isSignedIn() ? request.auth.token.email : null; }
    function isParentOfDoc(studentId) {
      return myRole() == 'parent'
        && get(/databases/$(database)/documents/students/$(studentId)).data.parentEmail == myEmail();
    }
    function isSupervisor(tournamentId) {
      return isStaff() && myEmail() != null &&
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.coachEmails.hasAny([myEmail()]);
    }

    // ── Perfiles de usuario ──────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == userId
                        && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ── Alumnos ────────────────────────────────────────────────────────────
    // El padre puede leer la ficha de su hijo y editar SOLO los campos de
    // contacto/adicional y la ficha médica (nunca categoría, entrenador,
    // estado ni el correo de vinculación).
    match /students/{id} {
      allow read:   if isStaff() || isParentOfDoc(id) || resource.data.parentEmail == null;
      allow write:  if isCoordinator();
      allow update: if isParentOfDoc(id)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['contact', 'medical', 'photoURL', 'parentPhone', 'updatedAt']);
      // Autorregistro de padres: un usuario reci\u00e9n autenticado (a\u00fan sin perfil
      // en /users) reclama al alumno usando el n\u00famero de documento (ver
      // login.html). Solo si el alumno a\u00fan no tiene un correo de padre
      // vinculado, y solo puede tocar ese campo, con SU PROPIO correo.
      allow update: if isSignedIn() && resource.data.parentEmail == null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentEmail', 'updatedAt'])
        && request.resource.data.parentEmail == myEmail();
    }

    match /categories/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }
    match /coaches/{id} {
      allow read:  if isStaff();
      allow write: if isCoordinator();
    }
    match /parents/{id} {
      allow read:  if isStaff();
      allow write: if isCoordinator();
    }

    // ── Operación diaria ──────────────────────────────────────────────────
    match /attendance/{id} {
      allow read:  if isStaff() || isParentOfDoc(resource.data.studentId);
      allow write: if isStaff();
    }
    match /payments/{id} {
      allow read:  if isStaff() || isParentOfDoc(resource.data.studentId);
      allow write: if isCoordinator();
    }
    match /tournaments/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }
    match /tournamentRegistrations/{id} {
      allow read:   if isStaff() || isParentOfDoc(resource.data.studentId);
      allow create: if isCoordinator() || isParentOfDoc(request.resource.data.studentId);
      allow update: if isCoordinator() || isSupervisor(resource.data.tournamentId)
        || (isParentOfDoc(resource.data.studentId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'cancelled');
      allow delete: if isCoordinator() || isParentOfDoc(resource.data.studentId);
    }
    match /tournamentUpdates/{id} {
      allow read:   if isSignedIn();
      allow create: if isCoordinator() || isSupervisor(request.resource.data.tournamentId);
      allow delete: if isCoordinator();
    }
    match /callUps/{id} {
      allow read:  if isStaff() || (myRole() == 'parent' && resource.data.status == 'approved');
      allow write: if isCoordinator() || isSupervisor(id);
    }
    match /schedules/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }

    // ── Ficha ampliada del alumno ──────────────────────────────────────────
    match /documents/{id} {
      allow read:   if isStaff() || isParentOfDoc(resource.data.studentId);
      allow create: if isCoordinator() || isParentOfDoc(request.resource.data.studentId);
      allow update, delete: if isCoordinator()
        || (isParentOfDoc(resource.data.studentId) && resource.data.uploadedByRole == 'parent');
    }
    match /photos/{id} {
      allow read:   if isStaff() || isParentOfDoc(resource.data.studentId);
      allow create: if isCoordinator() || isParentOfDoc(request.resource.data.studentId);
      allow delete: if isCoordinator()
        || (isParentOfDoc(resource.data.studentId) && resource.data.uploadedByRole == 'parent');
    }
    match /performanceNotes/{id} {
      allow read:  if isStaff() || isParentOfDoc(resource.data.studentId);
      allow write: if isStaff();
    }
    match /studentChangeLog/{id} {
      allow read:   if isStaff() || isParentOfDoc(resource.data.studentId);
      allow create: if isCoordinator() || isParentOfDoc(request.resource.data.studentId);
    }

    // ── Comunicación y notificaciones ──────────────────────────────────────
    match /announcements/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }
    match /notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.audience == 'all' ||
        (resource.data.audience == 'parents' && myRole() == 'parent') ||
        (resource.data.audience == 'coaches' && isStaff()) ||
        (resource.data.parentEmail != null && resource.data.parentEmail == myEmail())
      );
      allow create: if isStaff();
      allow update, delete: if isStaff();
    }

    // ── Reportes y configuración ──────────────────────────────────────────
    match /reports/{id} {
      allow read:  if isStaff();
      allow write: if isCoordinator();
    }
    match /settings/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /policies/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /policyAcceptances/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isStaff());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════
// Reglas de seguridad — Barsa Soacha Academy
// Roles: admin > coordinator > coach > parent (ver ROLES en firebase-config.js)
// ══════════════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myRole() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isAdmin()       { return myRole() == 'admin'; }
    function isCoordinator() { return myRole() in ['admin', 'coordinator']; }
    function isStaff()       { return myRole() in ['admin', 'coordinator', 'coach']; }
    function myEmail()       { return isSignedIn() ? request.auth.token.email : null; }
    function isParentOfDoc(studentId) {
      return myRole() == 'parent'
        && get(/databases/$(database)/documents/students/$(studentId)).data.parentEmail == myEmail();
    }

    // ── Perfiles de usuario ──────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == userId
                        && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ── Alumnos ────────────────────────────────────────────────────────────
    // El padre puede leer la ficha de su hijo y editar SOLO los campos de
    // contacto/adicional y la ficha médica (nunca categoría, entrenador,
    // estado ni el correo de vinculación).
    match /students/{id} {
      allow read:   if isStaff() || isParentOfDoc(id);
      allow write:  if isCoordinator();
      allow update: if isParentOfDoc(id)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['contact', 'medical', 'photoURL', 'updatedAt']);
    }

    match /categories/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }
    match /coaches/{id} {
      allow read:  if isStaff();
      allow write: if isCoordinator();
    }
    match /parents/{id} {
      allow read:  if isStaff();
      allow write: if isCoordinator();
    }

    // ── Operación diaria ──────────────────────────────────────────────────
    match /attendance/{id} {
      allow read:  if isStaff() || isParentOfDoc(resource.data.studentId);
      allow write: if isStaff();
    }
    match /payments/{id} {
      allow read:  if isStaff() || isParentOfDoc(resource.data.studentId);
      allow write: if isCoordinator();
    }
    match /tournaments/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }
    match /schedules/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }

    // ── Ficha ampliada del alumno ──────────────────────────────────────────
    match /documents/{id} {
      allow read:   if isStaff() || isParentOfDoc(resource.data.studentId);
      allow create: if isCoordinator() || isParentOfDoc(request.resource.data.studentId);
      allow update, delete: if isCoordinator()
        || (isParentOfDoc(resource.data.studentId) && resource.data.uploadedByRole == 'parent');
    }
    match /photos/{id} {
      allow read:   if isStaff() || isParentOfDoc(resource.data.studentId);
      allow create: if isCoordinator() || isParentOfDoc(request.resource.data.studentId);
      allow delete: if isCoordinator()
        || (isParentOfDoc(resource.data.studentId) && resource.data.uploadedByRole == 'parent');
    }
    match /performanceNotes/{id} {
      allow read:  if isStaff() || isParentOfDoc(resource.data.studentId);
      allow write: if isStaff();
    }

    // ── Comunicación y notificaciones ──────────────────────────────────────
    match /announcements/{id} {
      allow read:  if isSignedIn();
      allow write: if isCoordinator();
    }
    match /notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.audience == 'all' ||
        (resource.data.audience == 'parents' && myRole() == 'parent') ||
        (resource.data.audience == 'coaches' && isStaff()) ||
        (resource.data.parentEmail != null && resource.data.parentEmail == myEmail())
      );
      allow create: if isStaff();
      allow update, delete: if isStaff();
    }

    // ── Reportes y configuración ──────────────────────────────────────────
    match /reports/{id} {
      allow read:  if isStaff();
      allow write: if isCoordinator();
    }
    match /settings/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
